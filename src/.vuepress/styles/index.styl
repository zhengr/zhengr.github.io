@import "./fonts.styl"

// ============================================================
// Design tokens injected as CSS custom properties.
// Light by default; dark overrides on [data-theme="dark"].
// Components should *only* read via `var(--c-*)` where possible.
// ============================================================
:root
  // brand
  --c-accent #3b82f6
  --c-accent-soft rgba(59, 130, 246, 0.10)
  --c-accent-strong #2563eb
  // neutral (light)
  --c-bg #ffffff
  --c-bg-elev #fbfbfc
  --c-bg-subtle #f7f8fa
  --c-body #1f2937
  --c-body-muted #6b7280
  --c-body-faint #94a3b8
  --c-hairline #e5e7eb
  --c-hairline-strong #d1d5db
  --c-card #ffffff
  --c-card-shadow 0 1px 2px rgba(15, 23, 42, 0.04), 0 1px 1px rgba(15, 23, 42, 0.03)
  --c-card-shadow-hover 0 12px 28px rgba(15, 23, 42, 0.08), 0 4px 10px rgba(15, 23, 42, 0.04)
  --c-code-bg #0f172a
  --c-code-text #e5e7eb
  --c-inline-code-bg rgba(59, 130, 246, 0.08)
  --c-inline-code-text #1f2937
  --c-quote-bg #f7f8fa
  --c-quote-bar #3b82f6
  --c-link #2563eb
  --c-link-hover #1d4ed8
  --c-table-stripe #f9fafb
  // layout
  --container-width 1080px
  --content-width 820px
  --navbar-height 4.2rem
  // radius
  --radius-sm 6px
  --radius 10px
  --radius-lg 16px
  --radius-xl 24px

[data-theme="dark"]
  --c-accent #60a5fa
  --c-accent-soft rgba(96, 165, 250, 0.14)
  --c-accent-strong #93c5fd
  --c-bg #0b0f17
  --c-bg-elev #0f141d
  --c-bg-subtle #111827
  --c-body #e5e7eb
  --c-body-muted #94a3b8
  --c-body-faint #64748b
  --c-hairline #1f2735
  --c-hairline-strong #2a3548
  --c-card #111827
  --c-card-shadow 0 1px 2px rgba(0, 0, 0, 0.4)
  --c-card-shadow-hover 0 14px 30px rgba(0, 0, 0, 0.55), 0 6px 12px rgba(0, 0, 0, 0.35)
  --c-code-bg #060a14
  --c-code-text #e5e7eb
  --c-inline-code-bg rgba(96, 165, 250, 0.12)
  --c-inline-code-text #c9d1d9
  --c-quote-bg #111827
  --c-quote-bar #60a5fa
  --c-link #93c5fd
  --c-link-hover #bfdbfe
  --c-table-stripe #111827

// ============================================================
// Base
// ============================================================
* { box-sizing border-box }

html
  background-color var(--c-bg)
  scroll-behavior smooth

body
  margin 0
  padding 0
  font-hei()
  background-color var(--c-bg)
  color var(--c-body)
  line-height 1.6
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  text-rendering optimizeLegibility
  transition background-color .25s ease, color .25s ease

a
  color var(--c-link)
  text-decoration none
  transition color .15s ease
  &:hover
    color var(--c-link-hover)

// container
.page
  box-sizing border-box
  width calc(100% - 48px)
  max-width var(--container-width)
  margin-left auto
  margin-right auto

// selection
::selection
  background var(--c-accent-soft)
  color var(--c-accent-strong)

// scrollbar
::-webkit-scrollbar
  width 10px
  height 10px
::-webkit-scrollbar-track
  background transparent
::-webkit-scrollbar-thumb
  background rgba(125, 125, 125, 0.25)
  border-radius 8px
  &:hover
    background rgba(125, 125, 125, 0.45)

// loading light
.loading-light
  position relative
.loading-light:after
  content ''
  position absolute
  height 20px
  width 1000px
  background-color var(--c-bg)
  opacity .4
  left -500px
  animation fly-to-right 2s ease infinite

@keyframes fly-to-right
  from
    transform translateX(0px) rotate(45deg)
  to
    transform translateX(1000px) rotate(45deg)

// nice fade-in on first paint
@keyframes fade-up
  from
    opacity 0
    transform translateY(8px)
  to
    opacity 1
    transform translateY(0)
